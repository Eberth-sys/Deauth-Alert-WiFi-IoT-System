# ==========================================================================================================
# 📦 Archivo de ejemplo .env para la configuración del sistema IoT
# 🛠️ Este archivo contiene las variables necesarias para ejecutar el backend del proyecto.
#
# ⚠️ Importante: NO incluyas credenciales reales en este archivo.
# 📄 Cópialo y renómbralo como ".env" para realizar tus configuraciones reales.
# ==========================================================================================================

# -------------------- 🗄️ Configuración de la Base de Datos PostgreSQL --------------------

PG_DB=deauth_alerts                     # 📝 Escribe aquí el nombre de tu base de datos
PG_USER=your_username                   # 👤 Ingresa el usuario con permisos sobre la base de datos
PG_PASSWORD=your_secure_password        # 🔐 Añade aquí tu contraseña segura para PostgreSQL
PG_HOST=localhost                       # 🏠 Host de la BD. LOCAL → "localhost". DOCKER → el nombre del servicio/contenedor de Postgres en la red (ej. "postgres" o "deauth_postgres"), NUNCA "localhost".
PG_PORT=5432                            # 📍 Puerto donde PostgreSQL está escuchando (por defecto es 5432)

# 🔗 NOTA: el backend NO lee DATABASE_URL — la deriva automáticamente de PG_USER/PG_PASSWORD/PG_HOST/PG_PORT/PG_DB
#     (ver backend/src/database.py). No hace falta definirla aquí.

# -------------------- 🔐 Configuración de JWT (tokens de acceso) --------------------

JWT_SECRET_KEY=your_jwt_secret_key      # 🗝️ Clave secreta para firmar tokens JWT (elige una cadena larga y segura)
JWT_ALGORITHM=HS256                     # 🔄 Algoritmo usado para firmar los tokens (por defecto: HS256)
JWT_EXPIRE_MINUTES=1440                 # ⏰ Duración del token JWT en minutos (1440 = 24 horas)

# -------------------- 🤖 Configuración del Bot de Telegram --------------------

TELEGRAM_BOT_TOKEN=your_telegram_bot_token  # 🤖 Token que obtienes al crear tu bot con BotFather en Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id      # 💬 ID del usuario o grupo de Telegram que recibirá las alertas

# -------------------- 🌐 Orígenes permitidos para acceder a la API (CORS) --------------------

CORS_ORIGINS=http://localhost:5173,http://192.168.0.100:5173
# 🌍 Agrega aquí las URLs desde donde se accederá a tu backend (como tu frontend local o IPs permitidas)

# -------------------- 📝 Ruta para archivos de logs --------------------

LOGS_DIR=/ruta/a/tu/repositorio/processing-layer/logs
# 📁 Indica aquí la ruta donde se almacenarán los archivos de logs generados por el sistema

# -------------------- 🔗 URL del Frontend para redirecciones y correos --------------------

FRONTEND_URL=http://localhost:5173
# 🖥️ Esta URL se utiliza, por ejemplo, para generar enlaces de recuperación de contraseña

# -------------------- 🤝 Autenticación de servicio máquina-a-máquina (DEC-0005) --------------------

SERVICE_API_KEY=your_strong_service_api_key
# 🔑 Secreto compartido con la processing-layer (Raspberry Pi) para autenticar el POST /esp32-nodes/update.
# 🔒 Usa un valor aleatorio y fuerte (≥32 bytes). Genéralo con:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️ Debe coincidir EXACTAMENTE con BACKEND_SERVICE_API_KEY del .env de la processing-layer.
