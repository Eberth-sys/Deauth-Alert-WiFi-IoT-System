# ========================================================================
# 🌐 PLANTILLA DE CONFIGURACIÓN DE VARIABLES DE ENTORNO PARA EL FRONTEND
# Archivo: .env.example — ¡No pongas aquí datos reales o sensibles!
# Copia este archivo como `.env` y personalízalo según tu entorno 🌍
# ========================================================================

# -------------------- 🔗 URL del Backend (API HTTP REST) --------------------
VITE_BACKEND_URL=http://localhost:8000
# 📝 Especifica aquí la dirección donde corre tu API FastAPI.
# Ejemplos:
#   - Desarrollo local:  http://localhost:8000
#   - IP en red local:   http://192.168.1.100:8000
#   - Producción:        https://api.midominio.com

# -------------------- 📡 URL del WebSocket (tiempo real) --------------------
VITE_WS_URL=ws://localhost:8000
# 🛰️ Esta es la dirección WebSocket para recibir actualizaciones en vivo.
# Usa `ws://` para desarrollo local, y `wss://` si está en producción segura (HTTPS).
# Ejemplos:
#   - Local:      ws://localhost:8000
#   - Producción: wss://api.midominio.com

# 🎉 ¡Todo listo! Ejecuta tu frontend con `npm run dev` para comenzar 🚀
