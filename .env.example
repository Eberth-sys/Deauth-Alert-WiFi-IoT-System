# =============================================================================================
# 📄 .env.example — WEB-STACK Docker (postgres + backend)
# 📝 Copiá como ".env" (o pasá con --env-file) y reemplazá por tus valores.
# 🚫 NO pongas secretos reales aquí (esto es una plantilla versionada).
# 🔑 Generá secretos fuertes con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================================

# -------------------- 🗄️ PostgreSQL --------------------
PG_DB=deauth_alerts                     # 📝 Nombre de la base de datos
PG_USER=your_username                   # 👤 Usuario de PostgreSQL
PG_PASSWORD=your_secure_postgres_password   # 🔐 SECRETO — contraseña de PostgreSQL
PG_PORT=5432                            # 📍 Puerto EXPUESTO al host (el backend usa el 5432 interno de la red)
# ℹ️ PG_HOST: en el web-stack el backend usa el nombre de servicio "postgres" (lo fija el compose).
#            Para uso LOCAL sin Docker sería "localhost".

# -------------------- 🔐 JWT --------------------
JWT_SECRET_KEY=your_strong_jwt_secret_min_32_chars   # 🔑 SECRETO — ≥32 caracteres (el backend NO arranca si es más corta)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440                 # ⏰ 24 h

# -------------------- 🤝 Auth de servicio máquina-a-máquina (DEC-0005) --------------------
SERVICE_API_KEY=your_strong_service_api_key_min_32_chars   # 🔑 SECRETO — ≥32 caracteres; debe coincidir con la processing-layer

# -------------------- 🌐 CORS / Frontend --------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:8080   # 🌍 Orígenes permitidos (coma-separados, SIN espacios). :8080 = frontend Docker
FRONTEND_URL=http://localhost:5173      # 🖥️ Usada para enlaces de recuperación de contraseña

# -------------------- ⚛️ Frontend Docker (build-time · Vite hornea estas URLs en la imagen) --------------------
VITE_BACKEND_URL=http://localhost:8000  # 🔗 URL del backend para el frontend (cambiar de backend → rebuild)
VITE_WS_URL=ws://localhost:8000         # 🔌 URL WebSocket (misma config que REST)

# -------------------- 📝 Logs --------------------
LOGS_DIR=/app/logs                      # 📁 Ruta de logs DENTRO del contenedor del backend
