# ==============================================================
# Archivo de ejemplo para configuración MQTT (AWS IoT Core)
# ==============================================================

# 🔧 Instrucciones:
# 1. Copiá este archivo y renombralo como ".env" en la misma carpeta:
#    cp processing-layer/src/certs/.env.example processing-layer/src/certs/.env
# 2. Completá los valores reales según tu configuración.


# ==============================================================
# Parámetros de conexión MQTT
# ==============================================================

# Endpoint del broker MQTT (por ejemplo: AWS IoT Core)
MQTT_ENDPOINT=your-iot-endpoint.amazonaws.com

# Identificador del cliente (ejemplo: RaspberryPi-IoT)
MQTT_CLIENT_ID=your-client-id

# Tópico donde se publicarán las alertas
MQTT_TOPIC=alerts/deauthentication

# ==============================================================
# Rutas a los certificados (relativas a esta carpeta /src/certs)
# ==============================================================

MQTT_ROOT_CA=certs/AmazonRootCA1.pem
MQTT_CERT_FILE=certs/your-certificate.pem.crt
MQTT_KEY_FILE=certs/your-private.pem.key
