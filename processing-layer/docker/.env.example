#/docker/.env.example

# ╔════════════════════════════════════════════════════════════╗
# ║      ✨ ARCHIVO DE EJEMPLO PARA TU CONFIGURACIÓN .env       ║
# ║   ¡Hola! Personaliza cada línea con tus propios datos 😊   ║
# ║   Este archivo es solo una plantilla, no contiene claves   ║
# ╚════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────
# 🐘 CONEXIÓN A TU BASE DE DATOS POSTGRESQL
# ─────────────────────────────────────────────────────────────
PG_DB=deauth_alerts              # 📝 Escribe aquí el nombre de tu base de datos
PG_USER=your_username            # 👤 Escribe aquí tu usuario de PostgreSQL
PG_PASSWORD=your_secure_password # 🔒 Escribe aquí tu contraseña segura
PG_HOST=deauth_postgres          # 🛳️ Nombre del contenedor de PostgreSQL (¡no pongas "localhost"!)
PG_PORT=5432                     # 📍 Deja este puerto a menos que uses uno distinto

# ─────────────────────────────────────────────────────────────
# ☁️ DATOS PARA CONECTAR CON AWS IoT CORE (MQTT)
# ─────────────────────────────────────────────────────────────
MQTT_ENDPOINT=your-endpoint-ats.iot.your-region.amazonaws.com  # 🌐 Pega aquí tu endpoint MQTT de AWS
MQTT_CLIENT_ID=Your-RaspberryPi-Client                         # 🧠 Pon un nombre único a tu dispositivo (puede ser tu RPi)
MQTT_TOPIC=test/topic                                          # 🗂️ Tópico MQTT donde se publicarán alertas
MQTT_ROOT_CA=src/certs/AmazonRootCA1.pem                       # 📁 Ruta al certificado raíz
MQTT_CERT_FILE=src/certs/your-certificate.pem.crt              # 📜 Ruta al certificado de tu dispositivo
MQTT_KEY_FILE=src/certs/your-private.pem.key                   # 🔑 Ruta a tu clave privada

# ─────────────────────────────────────────────────────────────
# 🤖 CONFIGURA TU BOT DE TELEGRAM
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token  # 🪪 Pega aquí el token de tu bot (creado con @BotFather)
TELEGRAM_CHAT_ID=your_telegram_chat_id      # 💬 Pega aquí el ID del chat o grupo donde se enviarán los mensajes

# ─────────────────────────────────────────────────────────────
# 🚀 URL BASE DEL BACKEND FASTAPI
# ─────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000  # 🖥️ Usa localhost si trabajas localmente, cámbialo en producción

# ─────────────────────────────────────────────────────────────
# 💡 ¿CÓMO USAR ESTE ARCHIVO?
# ─────────────────────────────────────────────────────────────
# 📂 En consola:
# cd ~/GitHub/Deauth-Alert-WiFi-IoT-System/docker
# cp .env.example .env
# 🛠️ Luego edita el archivo `.env` con tus datos reales (¡este ejemplo es solo una guía!)
